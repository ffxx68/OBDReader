<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITOLO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 OBD-II Reader"
            android:textColor="#E0E0FF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Protocollo: --"
            android:textColor="#888AAA"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <!-- STATUS -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inizializzazione..."
            android:textColor="#A0A8FF"
            android:textSize="14sp"
            android:background="#2A2A40"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- PROGRESS BAR -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:indeterminateTint="#7B68EE"/>

        <!-- PULSANTI CONNESSIONE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnScan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍 Cerca dispositivi"
                android:backgroundTint="#4A4AFF"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔌 Disconnetti"
                android:backgroundTint="#FF4A6A"
                android:textColor="#FFFFFF"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- CARD RPM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252540"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvRpm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙️  RPM: --"
                android:textColor="#7BE8FF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CARD VELOCITÀ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252540"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚗  Velocità: --"
                android:textColor="#7BFFB0"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CARD TEMPERATURA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252540"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTemp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌡️  Temperatura: --"
                android:textColor="#FFB07B"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CARD DTC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252540"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvDtc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️  DTC: --"
                android:textColor="#FF8080"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- PULSANTI DATI -->
        <Button
            android:id="@+id/btnReadOnce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 Leggi tutti i dati"
            android:backgroundTint="#4A8CFF"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStartPolling"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔁 Avvia aggiornamento continuo"
            android:backgroundTint="#4ABA8C"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnClearDtc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Cancella codici errore (Mode 04)"
            android:backgroundTint="#8B4AFF"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
