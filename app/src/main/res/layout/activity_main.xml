<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Barra titolo con pulsante impostazioni -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="OBD-II Reader"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Impostazioni"
                android:padding="8dp"
                android:src="@drawable/ic_settings" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="4dp"
            android:text="Protocollo: --"
            android:textSize="16sp"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/tvElmVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="2dp"
            android:text="ELM327: --"
            android:textSize="13sp"
            android:textColor="#B0BEC5" />

        <TextView
            android:id="@+id/tvVin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:text="VIN: --"
            android:textSize="13sp"
            android:textColor="#B0BEC5" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="6dp"
            android:text="Inizializzazione..."
            android:textSize="16sp"
            android:textColor="@android:color/white" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="Connetti"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:minHeight="44dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="Disconnetti"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:minHeight="44dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </LinearLayout>

        <!-- Letture principali -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RPM:"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvRpm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Velocità:"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Temp:"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvTemp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Consumi istantanei -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="km/L ist. (MAF):"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvFuelRateInstantMaf"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="km/L ist. (SD):"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvFuelRateInstantSd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Statistiche di viaggio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Km percorsi:"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvTotalKm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Velocità media:"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvAvgSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="km/L medio (MAF):"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvAvgFuelMaf"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="km/L medio (SD):"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:paddingEnd="12dp"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvAvgFuelSd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start"
                android:textColor="#4CAF50" />
        </LinearLayout>



    </LinearLayout>
</ScrollView>


</LinearLayout>
